# ===== Docker Deployment Configuration Template =====
#
# IMPORTANT:
# 1. Copy this file to .env in the docker/ directory
# 2. Replace all placeholder values with strong, random secrets
# 3. DO NOT commit .env to version control (it's in .gitignore)
# 4. Use a secrets management system in production (AWS Secrets Manager, HashiCorp Vault, etc.)
#
# To generate strong random values, use:
#   - openssl rand -base64 32     (for passwords and salts)
#   - python -c "import secrets; print(secrets.token_urlsafe(32))"  (for API keys)
#

# ===== Server Configuration =====

# Server bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
# In Docker: use 0.0.0.0 to listen on all interfaces
# Default: 0.0.0.0
PKI_HOST=0.0.0.0

# Server port (must match the exposed port in docker-compose.yml)
# Default: 8000
PKI_PORT=8000

# PKI web app base URL used when building CRL Distribution Point URLs in issued certs.
# For cloud deployments, use your actual domain (e.g., https://pki.example.com)
# Default: http://localhost:8000
PKI_BASE_URL=http://localhost:8000

# Recreate invalid database file from schema at startup (true/false).
# WARNING: true will replace an invalid DB file and keep a *.invalid.bak backup.
# Default: false
PKI_DB_AUTO_REINIT=false

# ===== Storage Paths (already set in Dockerfile, shown here for reference) =====
#
# These MUST match the volume mount points in docker-compose.yml
# In Docker, these are already configured in the Dockerfile to:
#   PKI_DATA_DIR=/app/data              (encrypted certificate artifacts)
#   PKI_DB_PATH=/app/database/pki.db    (SQLite database file)
#
# Uncomment and modify below ONLY if you need to override the defaults.
# If overridden, values MUST be absolute paths and MUST match volume mount points in docker-compose.yml.
#
# PKI_DATA_DIR=/app/data
# PKI_DB_PATH=/app/database/pki.db

# ===== Certificate Generation =====

# Optional fixed passphrase for root CA key generation.
# If empty, a random password file is generated.
# Default: (empty - auto-generate)
PKI_PASS=

# ===== Notifications (Optional) =====
#
# Only needed if you want to enable email or webhook notifications.
# By default, only log-based notifications are enabled.

# Notification mode for scripts/notify_expiring.py
# Allowed: log | email | webhook
# Default: log
# NOTIFY_METHOD=log

# SMTP settings (used when NOTIFY_METHOD=email)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_TO=admin@example.com,ops@example.com

# Webhook endpoint (used when NOTIFY_METHOD=webhook)
# WEBHOOK_URL=

# ===== Encryption at Rest (REQUIRED) =====

# Strong password for encrypting all certificate artifacts at rest (*.pem.enc, *.key.enc, etc.)
# REQUIRED for production. Must be a strong, random password (32+ characters recommended).
# Generate with: openssl rand -base64 32
# IMPORTANT: Must be the same across all instances accessing the same data
PKI_ENCRYPTION_KEY=Zl2bj25gk4tkLqVvx526IOOWt4yakgQ+TgG5RB5yfVI=

# Random salt for PBKDF2 key derivation.
# REQUIRED for production. Must be unique per installation.
# Generate once and keep consistent: openssl rand -base64 32
# IMPORTANT: Changing this after initial setup will make all encrypted artifacts inaccessible
PKI_ENCRYPTION_SALT=phm4Rp0ukz6y9j4Jm8ZhIzCTtUqWR898dISXlrv6ivM=

# ===== Authentication (Session JWT with Role-Based Access Control) =====

# Three API keys, one per role: admin (full access), manager (end-entity cert creation), user (read-only)
# Each key must be unique and strong (32+ random characters recommended).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PKI_API_KEY_ADMIN=Iv18OOC4I+b99OMqbBPAz8xBxiG1lZLKHn8yKZcnt3s=
PKI_API_KEY_MANAGER=3+AO6fr/0zY7U5b+CBhiTmHF9dBJckCaZvPWFIdDzBU=
PKI_API_KEY_USER=Wh7KI1bvE4tw5F+anelcO3ZkRtX6YkpLj1tD7iEZrzQ=

# Secret used to sign/verify JWT sessions (HS256)
# Must be strong and random (32+ characters recommended).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PKI_JWT_SECRET=0QQAgoHttl8D9+3LJ/40Ujx+veSJyCJ69RUsZAK+/ac=

# Session duration in minutes.
# Sessions expire after this duration; user must re-authenticate.
# Default: 15
PKI_SESSION_MINUTES=15

# Cookie name that stores the JWT session in the browser.
# Change only if you need to avoid conflicts with another app on same host/domain.
# Default: pki_session
PKI_AUTH_COOKIE_NAME=pki_session

# Cookie security settings
# true: send cookie only over HTTPS (required for production)
# false: allow local HTTP development
# Default: true (HTTPS only)
# In Docker: set to true in production, false for local development
PKI_COOKIE_SECURE=true

# SameSite policy for CSRF/cross-site behavior:
# - lax: recommended default for normal navigation/forms
# - strict: strongest, but can break some flows
# - none: needed for cross-site use (requires PKI_COOKIE_SECURE=true)
# Default: lax
PKI_COOKIE_SAMESITE=lax

# Optional domain scope for the cookie (empty = host-only cookie).
# Use host-only cookies for single-host deployments.
# Example: .example.com to share session across subdomains (advanced use case)
# Default: (empty - host-only)
PKI_COOKIE_DOMAIN=

# ===== Logging Configuration =====

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Controls verbosity of application logs
# - DEBUG: very verbose, shows internal operations
# - INFO: normal operations, key events
# - WARNING: only warnings and errors
# - ERROR: only errors
# Default: INFO
# Production recommendation: WARNING
PKI_LOG_LEVEL=INFO

# ===== Subprocess Configuration =====

# Timeout for certificate generation operations (seconds).
# Certificates are generated via subprocess calls to openssl.
# Increase if your system is slow or generating large key sizes.
# Default: 120 (2 minutes)
PKI_SUBPROCESS_TIMEOUT_SECONDS=120
